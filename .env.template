# =============================================================================
# cloudfared-tunnel — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#   cp .env.template .env
#
# The .env file is gitignored — your secrets stay local.
# =============================================================================

# ── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Your Cloudflare tunnel token (eyJ...). Get it from:
#   Cloudflare Dashboard → Zero Trust → Networks → Tunnels → your-tunnel
CLOUDFLARED_TOKEN=

# ── SSH / Domain ─────────────────────────────────────────────────────────────
# The public hostname configured in your Cloudflare tunnel
DOMAIN=ssh.your-domain.com

# SSH username for tunnel access
SSH_USER=duke

# ── Advanced (optional) ───────────────────────────────────────────────────────
# cloudflared metrics endpoint (default: http://127.0.0.1:20241/metrics)
METRICS_URL=http://127.0.0.1:20241/metrics

# systemd service unit name (default: cloudflared-tunnel.service)
SERVICE_NAME=cloudflared-tunnel.service
